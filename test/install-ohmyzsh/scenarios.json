{
    "apt_no_git": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-ohmyzsh": {}
        }
    },
    "apt_default": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-ohmyzsh": {}
        }
    },
    "apt_no_fonts": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-ohmyzsh": {
                "install_fonts": false
            }
        }
    },
    "apt_configure_zshrc": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-ohmyzsh": {
                "configure_zshrc_for": "root"
            }
        }
    }
}
