{
    "inline_env": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "myenv",
                "packages": "numpy pandas",
                "debug": true
            }
        }
    },
    "python_version": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "py311",
                "python_version": "3.11",
                "debug": true
            }
        }
    },
    "env_files": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/simple.yml",
                "debug": true
            }
        }
    },
    "env_dirs": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_dirs": "/tmp/test-envs",
                "debug": true
            }
        }
    },
    "multi_env_files": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/envA.yml,/tmp/test-envs/envB.yml",
                "debug": true
            }
        }
    },
    "update_existing": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/simple.yml",
                "debug": true
            }
        }
    },
    "channels": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "chanenv",
                "packages": "numpy",
                "channels": "conda-forge :: defaults",
                "debug": true
            }
        }
    },
    "strict_channel_priority": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "strictenv",
                "packages": "numpy",
                "channels": "conda-forge",
                "strict_channel_priority": true,
                "debug": true
            }
        }
    },
    "solver_conda": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "solverenv",
                "packages": "numpy",
                "solver": "conda",
                "debug": true
            }
        }
    },
    "pip_requirements": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_name": "pipenv",
                "packages": "pip",
                "pip_requirements_files": "/tmp/requirements.txt",
                "debug": true
            }
        }
    },
    "pip_env_override": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_name": "pipenv",
                "packages": "pip",
                "pip_requirements_files": "/tmp/requirements.txt",
                "pip_env": "pipenv",
                "debug": true
            }
        }
    },
    "post_env_script": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_name": "scriptenv",
                "packages": "numpy",
                "post_env_script": "/tmp/post-env.sh",
                "debug": true
            }
        }
    },
    "logfile": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "logenv",
                "packages": "numpy",
                "logfile": "/tmp/conda-env.log",
                "debug": true
            }
        }
    },
    "keep_cache": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "cleanenv",
                "packages": "numpy",
                "keep_cache": true,
                "debug": true
            }
        }
    }
}
