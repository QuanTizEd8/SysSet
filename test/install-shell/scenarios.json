{
    "apt_default": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "debug": true
            }
        }
    },
    "apt_zsh_only": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "install_ohmyzsh": false,
                "install_ohmybash": false,
                "install_starship": false,
                "debug": true
            }
        }
    },
    "apt_no_fonts": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "install_ohmyzsh": false,
                "install_ohmybash": false,
                "install_starship": false,
                "debug": true
            }
        }
    },
    "apt_multi_plugins": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile"
        },
        "features": {
            "install-shell": {
                "ohmyzsh_plugins": "zsh-users/zsh-autosuggestions\nzsh-users/zsh-syntax-highlighting",
                "add_current_user": true,
                "debug": true
            }
        }
    },
    "apt_set_shell_zsh": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "set_user_shells": "zsh",
                "add_users": "root",
                "debug": true
            }
        }
    },
    "apt_omz_p10k": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "ohmyzsh_theme": "romkatv/powerlevel10k",
                "starship_shells": "",
                "add_users": "root",
                "debug": true
            }
        }
    },
    "apt_starship_only": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "install_ohmyzsh": false,
                "install_ohmybash": false,
                "install_starship": true,
                "debug": true
            }
        }
    },
    "apt_custom_dirs": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "ohmyzsh_install_dir": "/opt/oh-my-zsh",
                "ohmybash_install_dir": "/opt/oh-my-bash",
                "debug": true
            }
        }
    },
    "apt_no_git": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "debug": true
            }
        }
    },
    "apt_user_config": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "debug": true
            }
        }
    },
    "apt_user_config_skip": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "user_config_mode": "skip",
                "debug": true
            }
        }
    },
    "apt_zdotdir_default": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "debug": true
            }
        }
    },
    "apt_zdotdir_custom": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "zdotdir": "~/.zsh",
                "debug": true
            }
        }
    },
    "apt_custom_dir_system": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "ohmyzsh_custom_dir": "/opt/zsh-custom",
                "debug": true
            }
        }
    },
    "apt_custom_dir_per_user": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "ohmyzsh_custom_dir": "~/.zsh-custom",
                "debug": true
            }
        }
    },
    "apt_augment_mode": {
        "build": {
            "dockerfile": "Dockerfile"
        },
        "features": {
            "install-shell": {
                "user_config_mode": "augment",
                "debug": true
            }
        }
    },
    "apt_skel_placement": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "debug": true
            }
        }
    },
    "apt_omb_user_config": {
        "image": "debian:latest",
        "features": {
            "install-shell": {
                "debug": true
            }
        }
    },
    "apt_remote_user": {
        "image": "mcr.microsoft.com/devcontainers/base:debian",
        "remoteUser": "vscode",
        "features": {
            "install-shell": {
                "add_remote_user": true,
                "debug": true
            }
        }
    },
    "apt_container_user": {
        "image": "mcr.microsoft.com/devcontainers/base:debian",
        "containerUser": "vscode",
        "features": {
            "install-shell": {
                "add_container_user": true,
                "debug": true
            }
        }
    },
    "apt_add_users": {
        "build": {
            "dockerfile": "Dockerfile"
        },
        "features": {
            "install-shell": {
                "add_users": "devuser",
                "add_container_user": false,
                "add_remote_user": false,
                "debug": true
            }
        }
    }
}
