{
    "apt_default": {
        "remoteUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "debug": true
            }
        }
    },
    "apt_root_user_config": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "add_users": "root",
                "debug": true
            }
        }
    },
    "apt_remote_user": {
        "remoteUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "add_remote_user": true,
                "add_container_user": false,
                "add_current_user": false,
                "debug": true
            }
        }
    },
    "apt_container_user": {
        "containerUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "add_container_user": true,
                "add_remote_user": false,
                "add_current_user": false,
                "debug": true
            }
        }
    },
    "apt_explicit_user": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "add_users": "devuser",
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "debug": true
            }
        }
    },
    "apt_multi_user": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "add_users": "alice\nbob",
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "debug": true
            }
        }
    },
    "apt_no_users": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "debug": true
            }
        }
    },
    "apt_nonexistent_user": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-podman": {
                "add_users": "ghost",
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "debug": true
            }
        }
    }
}
