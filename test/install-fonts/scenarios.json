{
    "apt_default": {
        "image": "debian:latest",
        "features": {
            "install-fonts": {
                "debug": true
            }
        }
    },
    "apt_p10k_fonts": {
        "image": "debian:latest",
        "features": {
            "install-fonts": {
                "p10k_fonts": true,
                "debug": true
            }
        }
    },
    "apt_custom_font_dir": {
        "image": "debian:latest",
        "features": {
            "install-fonts": {
                "font_dir": "/opt/fonts",
                "debug": true
            }
        }
    },
    "apt_empty_nerd_fonts": {
        "image": "debian:latest",
        "features": {
            "install-fonts": {
                "nerd_fonts": "",
                "debug": true
            }
        }
    },
    "apt_font_urls": {
        "image": "debian:latest",
        "features": {
            "install-fonts": {
                "nerd_fonts": "",
                "font_urls": "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/NerdFontsSymbolsOnly.tar.xz",
                "debug": true
            }
        }
    },
    "apt_font_urls_file": {
        "image": "debian:latest",
        "features": {
            "install-fonts": {
                "nerd_fonts": "",
                "font_urls": "https://github.com/JetBrains/JetBrainsMono/raw/v2.304/fonts/ttf/JetBrainsMono-Regular.ttf",
                "debug": true
            }
        }
    },
    "apt_gh_release_fonts": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": { "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}" }
        },
        "features": {
            "install-fonts": {
                "nerd_fonts": "",
                "gh_release_fonts": "JetBrains/JetBrainsMono",
                "debug": true
            }
        }
    },
    "apt_gh_release_fonts_tag": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": { "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}" }
        },
        "features": {
            "install-fonts": {
                "nerd_fonts": "",
                "gh_release_fonts": "JetBrains/JetBrainsMono@v2.304",
                "debug": true
            }
        }
    }
}
