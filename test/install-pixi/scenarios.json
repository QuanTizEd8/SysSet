{
    "default_install": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "debug": true
            }
        }
    },
    "specific_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "version": "0.41.0",
                "debug": true
            }
        }
    },
    "custom_bin_dir": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "prefix": "/opt/pixi",
                "symlink": false,
                "debug": true
            }
        }
    },
    "custom_bin_dir_symlink": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "prefix": "/opt/pixi",
                "symlink": true,
                "debug": true
            }
        }
    },
    "debian": {
        "image": "debian:latest",
        "features": {
            "install-pixi": {
                "debug": true
            }
        }
    },
    "if_exists_skip": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-pixi": {
                "if_exists": "skip",
                "debug": true
            }
        }
    },
    "if_exists_reinstall": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-pixi": {
                "if_exists": "reinstall",
                "debug": true
            }
        }
    },
    "if_exists_update": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "if_exists": "update",
                "debug": true
            }
        }
    },
    "if_exists_update_existing": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-pixi": {
                "version": "latest",
                "if_exists": "update",
                "debug": true
            }
        }
    },
    "version_match_idempotency": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-pixi": {
                "version": "0.41.0",
                "if_exists": "reinstall",
                "debug": true
            }
        }
    },
    "version_match_path_only_symlink": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-pixi": {
                "version": "0.41.0",
                "prefix": "/opt/pixi",
                "symlink": true,
                "debug": true
            }
        }
    },
    "keep_installer": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "keep_installer": true,
                "debug": true
            }
        }
    },
    "export_path_disabled": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "prefix": "/opt/pixi",
                "export_path": "",
                "symlink": false,
                "debug": true
            }
        }
    },
    "shell_completion_bash": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "shell_completions": "bash",
                "debug": true
            }
        }
    },
    "shell_completion_zsh": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "shell_completions": "zsh",
                "debug": true
            }
        }
    },
    "home_dir": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "home_dir": "/var/pixi",
                "debug": true
            }
        }
    },
    "logfile": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "logfile": "/tmp/pixi.log",
                "debug": true
            }
        }
    },
    "custom_bin_dir_symlink_nonroot": {
        "remoteUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-pixi": {
                "prefix": "/opt/pixi",
                "symlink": true,
                "debug": true
            }
        }
    },
    "symlink_user_home_prefix": {
        "image": "ubuntu:latest",
        "features": {
            "install-pixi": {
                "prefix": "/root/pixi",
                "symlink": true,
                "debug": true
            }
        }
    }
}
