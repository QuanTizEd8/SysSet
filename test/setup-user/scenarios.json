{
    "default": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {}
        }
    },
    "no_sudo": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "sudo_access": false
            }
        }
    },
    "custom_user": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "username": "devuser",
                "user_id": "2000",
                "group_id": "2000",
                "group_name": "devgroup"
            }
        }
    },
    "custom_home": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "home_dir": "/workspaces/myapp"
            }
        }
    },
    "custom_shell": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "user_shell": "/bin/sh"
            }
        }
    },
    "extra_groups": {
        "build": {
            "dockerfile": "Dockerfile"
        },
        "features": {
            "setup-user": {
                "extra_groups": "builders,testers"
            }
        }
    },
    "replace_existing": {
        "build": {
            "dockerfile": "Dockerfile"
        },
        "features": {
            "setup-user": {}
        }
    },
    "already_configured": {
        "build": {
            "dockerfile": "Dockerfile"
        },
        "features": {
            "setup-user": {
                "replace_existing": false,
                "sudo_access": false
            }
        }
    },
    "alpine": {
        "image": "alpine:latest",
        "features": {
            "setup-user": {}
        }
    },
    "logfile": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "logfile": "/tmp/setup-user.log"
            }
        }
    }
}
