{
    "download_and_install": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "debug": true
            }
        }
    },
    "custom_bin_dir": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "prefix": "/opt/myforge", "symlink": false, "debug": true }
        }
    },
    "specific_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "version": "24.7.1", "debug": true }
        }
    },
    "set_permission": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "set_permissions": true, "debug": true }
        }
    },
    "activate_bashrc": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "shell_activations": "bash", "debug": true }
        }
    },
    "activate_multi": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "shell_activations": "bash zsh", "debug": true }
        }
    },
    "custom_active_env": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "shell_activations": "bash",
                "activate_env": "myenv",
                "debug": true
            }
        }
    },
    "logfile": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "logfile": "/tmp/miniforge.log", "debug": true }
        }
    },
    "keep_installer": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "keep_installer": true, "debug": true }
        }
    },
    "if_exists_reinstall": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "if_exists": "reinstall", "debug": true }
        }
    },
    "if_exists_skip": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "if_exists": "skip", "debug": true }
        }
    },
    "if_exists_fail": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "if_exists": "fail", "debug": true }
        }
    },
    "if_exists_update": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "if_exists": "update", "debug": true }
        }
    },
    "debian": {
        "image": "debian:latest",
        "features": {
            "install-miniforge": {
                "debug": true
            }
        }
    },
    "multi_user_permissions": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "set_permissions": true, "users": "testuser1,testuser2", "debug": true }
        }
    },
    "export_path_default": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "debug": true
            }
        }
    },
    "export_path_custom_dir": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "prefix": "/opt/myforge", "symlink": false, "debug": true }
        }
    },
    "export_path_symlink": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "prefix": "/opt/myforge", "symlink": true, "debug": true }
        }
    },
    "export_path_disabled": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "export_path": "", "debug": true }
        }
    },
    "export_path_custom_list": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": { "export_path": "/tmp/test_bashrc", "debug": true }
        }
    },
    "export_path_idempotency": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "prefix": "/opt/myforge", "symlink": false, "debug": true }
        }
    },
    "latest_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "debug": true
            }
        }
    },
    "version_match_idempotency": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "version": "24.7.1", "if_exists": "reinstall", "debug": true }
        }
    },
    "preserve_envs_true": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "if_exists": "reinstall", "preserve_envs": true, "debug": true }
        }
    },
    "preserve_envs_false": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "if_exists": "reinstall", "preserve_envs": false, "debug": true }
        }
    },
    "preserve_config_true": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "if_exists": "reinstall", "preserve_config": true, "debug": true }
        }
    },
    "preserve_config_false": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "if_exists": "reinstall", "preserve_config": false, "debug": true }
        }
    },
    "if_exists_update_preinstall": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "if_exists": "update", "debug": true }
        }
    },
    "export_path_symlink_nonroot": {
        "remoteUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-miniforge": { "prefix": "/opt/myforge", "symlink": true, "debug": true }
        }
    }
}
