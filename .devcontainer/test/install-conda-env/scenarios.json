{
    "inline_env": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "myenv",
                "packages": "numpy pandas"
            }
        }
    },
    "python_version": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "py311",
                "python_version": "3.11"
            }
        }
    },
    "env_files": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/simple.yml"
            }
        }
    },
    "env_dirs": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_dirs": "/tmp/test-envs"
            }
        }
    },
    "multi_env_files": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/envA.yml :: /tmp/test-envs/envB.yml"
            }
        }
    },
    "update_existing": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/simple.yml"
            }
        }
    },
    "channels": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "chanenv",
                "packages": "numpy",
                "channels": "conda-forge :: defaults"
            }
        }
    },
    "strict_channel_priority": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "strictenv",
                "packages": "numpy",
                "channels": "conda-forge",
                "strict_channel_priority": true
            }
        }
    },
    "solver_conda": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "solverenv",
                "packages": "numpy",
                "solver": "conda"
            }
        }
    },
    "pip_requirements": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_name": "pipenv",
                "packages": "pip",
                "pip_requirements_files": "/tmp/requirements.txt"
            }
        }
    },
    "pip_env_override": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_name": "pipenv",
                "packages": "pip",
                "pip_requirements_files": "/tmp/requirements.txt",
                "pip_env": "pipenv"
            }
        }
    },
    "post_env_script": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-conda-env": {
                "env_name": "scriptenv",
                "packages": "numpy",
                "post_env_script": "/tmp/post-env.sh"
            }
        }
    },
    "logfile": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "logenv",
                "packages": "numpy",
                "logfile": "/tmp/conda-env.log"
            }
        }
    },
    "no_cache_clean": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "cleanenv",
                "packages": "numpy",
                "no_cache_clean": true
            }
        }
    }
}
