{
    "apt_default": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {}
        }
    },
    "apt_zsh_only": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "install_ohmyzsh": false,
                "install_ohmybash": false,
                "install_starship": false
            }
        }
    },
    "apt_no_fonts": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "install_ohmyzsh": false,
                "install_ohmybash": false,
                "install_starship": false
            }
        }
    },
    "apt_multi_plugins": {
        "remoteUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "ohmyzsh_plugins": "zsh-users/zsh-autosuggestions,zsh-users/zsh-syntax-highlighting",
                "add_current_user_config": true
            }
        }
    },
    "apt_set_shell_zsh": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "set_user_shells": "zsh",
                "add_root_user_config": true
            }
        }
    },
    "apt_omz_p10k": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "ohmyzsh_theme": "romkatv/powerlevel10k",
                "starship_shells": "",
                "add_root_user_config": true
            }
        }
    },
    "apt_starship_only": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "install_ohmyzsh": false,
                "install_ohmybash": false,
                "install_starship": true
            }
        }
    },
    "apt_custom_dirs": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "ohmyzsh_install_dir": "/opt/oh-my-zsh",
                "ohmybash_install_dir": "/opt/oh-my-bash",
                "add_root_user_config": true
            }
        }
    },
    "apt_no_git": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {}
        }
    },
    "apt_user_config": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_root_user_config": true
            }
        }
    },
    "apt_user_config_skip": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_root_user_config": true,
                "user_config_mode": "skip"
            }
        }
    },
    "apt_zdotdir_default": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_root_user_config": true
            }
        }
    },
    "apt_zdotdir_custom": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "zdotdir": "~/.zsh",
                "add_root_user_config": true
            }
        }
    },
    "apt_custom_dir_system": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "ohmyzsh_custom_dir": "/opt/zsh-custom",
                "add_root_user_config": true
            }
        }
    },
    "apt_custom_dir_per_user": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "ohmyzsh_custom_dir": "~/.zsh-custom",
                "add_root_user_config": true
            }
        }
    },
    "apt_augment_mode": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_root_user_config": true,
                "user_config_mode": "augment"
            }
        }
    },
    "apt_skel_placement": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_root_user_config": true
            }
        }
    },
    "apt_omb_user_config": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_root_user_config": true
            }
        }
    },
    "apt_remote_user_config": {
        "remoteUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_remote_user_config": true
            }
        }
    },
    "apt_container_user_config": {
        "containerUser": "vscode",
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_container_user_config": true
            }
        }
    },
    "apt_add_user_config": {
        "build": { "dockerfile": "Dockerfile" },
        "features": {
            "install-shell": {
                "add_user_config": "devuser"
            }
        }
    }
}
