#!/bin/sh
# podman-run-persistent - run a command in a long-lived container instance.
#
# Usage: podman-run-persistent [podman-run options] IMAGE [COMMAND [ARGS...]]
#
# Behaves like `podman run --rm` but avoids creating a new container rootfs on
# every invocation. Instead it maintains a single persistent container per image
# (keyed by image reference) and executes commands via `podman exec`.
#
# Why this matters with VFS storage driver:
#   VFS copies all image layers into a fresh directory for every new container.
#   For large images (e.g. a ~1 GB document compiler), this means ~1 GB written
#   on every `podman run --rm`. With a persistent container the copy happens once
#   at first invocation; subsequent runs use `podman exec` with no copy overhead.
#
# Supported podman-run options (passed through to container creation):
#   -v / --volume     volume mounts
#   -w / --workdir    working directory
#   -e / --env        environment variables
#   --userns          user namespace mode
#   --tls-verify      TLS verification for image pulls
#   --network         network mode
#
# Limitations:
#   - One persistent container per image tag. If you need two simultaneous
#     independent instances of the same image, use plain `podman run`.
#   - The container is never automatically removed. Run
#     `podman rm -f <container-name>` to reset it.
#   - Volume mounts and working directory are fixed at container creation time.
#     If you change mounts between invocations, remove the container first.

set -e

# ---------------------------------------------------------------------------
# Parse arguments: separate podman-run options from IMAGE and COMMAND.
# We collect -v, -w, -e, --userns, --tls-verify, --network for `podman create`.
# Everything after the first non-option, non-flag argument is IMAGE [COMMAND...].
# ---------------------------------------------------------------------------
CREATE_OPTS=""
IMAGE=""
CMD=""

while [ $# -gt 0 ]; do
    case "$1" in
        -v|--volume|-w|--workdir|-e|--env|--userns|--network)
            CREATE_OPTS="${CREATE_OPTS} $1 $2"
            shift 2
            ;;
        --volume=*|--workdir=*|--env=*|--userns=*|--network=*)
            CREATE_OPTS="${CREATE_OPTS} $1"
            shift
            ;;
        --tls-verify|--tls-verify=*)
            # Passed to pull/create, not exec
            CREATE_OPTS="${CREATE_OPTS} $1"
            shift
            ;;
        --rm)
            # Silently accepted and ignored — persistence is the whole point
            shift
            ;;
        -*)
            # Unknown option — pass through to create
            CREATE_OPTS="${CREATE_OPTS} $1"
            shift
            ;;
        *)
            IMAGE="$1"
            shift
            CMD="$*"
            break
            ;;
    esac
done

if [ -z "${IMAGE}" ]; then
    echo "Usage: podman-run-persistent [OPTIONS] IMAGE [COMMAND [ARGS...]]" >&2
    exit 1
fi

# Derive a stable container name from the image reference (strip registry/tag,
# replace non-alphanumeric characters with hyphens).
CONTAINER_NAME="persistent-$(echo "${IMAGE}" | sed 's|.*/||; s|[^a-zA-Z0-9]|-|g')"

# ---------------------------------------------------------------------------
# Ensure the persistent container exists and is running.
# ---------------------------------------------------------------------------
if ! podman container exists "${CONTAINER_NAME}" 2>/dev/null; then
    # First invocation: create the container with a sleeping init process.
    # shellcheck disable=SC2086
    podman create \
        --name "${CONTAINER_NAME}" \
        --entrypoint '["sleep", "infinity"]' \
        ${CREATE_OPTS} \
        "${IMAGE}" > /dev/null
fi

if ! podman container inspect --format '{{.State.Running}}' "${CONTAINER_NAME}" 2>/dev/null | grep -q '^true$'; then
    podman start "${CONTAINER_NAME}" > /dev/null
fi

# ---------------------------------------------------------------------------
# Execute the requested command in the running container.
# -i: pass stdin through; omit -t (no TTY allocation needed for scripted use).
# ---------------------------------------------------------------------------
if [ -n "${CMD}" ]; then
    # shellcheck disable=SC2086
    exec podman exec -i "${CONTAINER_NAME}" ${CMD}
else
    exec podman exec -i "${CONTAINER_NAME}" sh
fi
