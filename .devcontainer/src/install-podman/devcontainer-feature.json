{
    "id": "install-podman",
    "version": "2.0.0",
    "name": "Rootless Podman",
    "description": "Installs Podman for rootless container execution inside a dev container. Uses native overlay storage on the named volume for fast copy-on-write container creation.",
    "documentationURL": "https://github.com/containers/podman",
    "keywords": ["podman", "containers", "rootless", "oci"],

    // Rootless Podman inside a container needs two things:
    //
    //   1. clone(CLONE_NEWUSER) — blocked by Docker/containerd's default
    //      seccomp profile.  Fixed by securityOpt "seccomp=unconfined".
    //
    //   2. newuidmap / newgidmap must run as setuid-root to write UID/GID
    //      mappings into /proc/<pid>/uid_map.  Docker mounts the container
    //      rootfs with nosuid, which neuters setuid binaries.  Fixed by
    //      granting CAP_SYS_ADMIN (via capAdd) and remounting / with suid
    //      at container startup (see configure-storage.sh).
    //
    // This avoids "privileged: true", which would disable ALL security
    // features (seccomp, AppArmor/SELinux, capability restrictions, and
    // read-only /proc and /sys paths) — far more than what Podman needs.
    "capAdd": ["SYS_ADMIN", "MKNOD"],
    "securityOpt": ["seccomp=unconfined", "apparmor=unconfined", "label=disable"],

    // Named volume for Podman's image/container storage.  The volume is
    // backed by the host's real filesystem (ext4/xfs/btrfs), NOT the
    // container's overlayfs root.  This lets Podman use the native kernel
    // overlay driver on the volume — avoiding the overlay-on-overlay problem
    // and the fuse-overlayfs noexec issue in nested user namespaces.
    "mounts": [
        {
            "source": "podman-storage-${devcontainerId}",
            "target": "/var/lib/containers/storage",
            "type": "volume"
        }
    ],

    // Entrypoint runs as root at every container startup.  It:
    //   1. Remounts / with suid so newuidmap/newgidmap work.
    //   2. Creates /dev/net/tun for slirp4netns networking.
    //   3. Remounts /proc unrestricted for inner container setup.
    //   4. Writes storage.conf with native overlay on the named volume.
    "entrypoint": "/usr/local/bin/podman-configure-storage",

    "options": {
        "version": {
            "type": "string",
            "default": "apt",
            "description": "Version of Podman to install. Use 'apt' to install the latest version available in the distribution's package manager.",
            "proposals": ["apt"]
        }
    }
}
