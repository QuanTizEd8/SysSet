# /etc/zsh/zshrc: system-wide .zshrc file for zsh(1).
#
# This file is sourced only for interactive shells. It
# should contain commands to set up aliases, functions,
# options, key bindings, etc.
#
# Global Order: zshenv, zprofile, zshrc, zlogin


# --- Interactivity guard ----------------------------------------------- #
# Return immediately if not running interactively; nothing below makes    #
# sense for non-interactive shells (scripts, scp, rsync, etc.).           #
case $- in
  *i*) ;;
    *) return;;
esac


# --- Shared shell configuration ----------------------------------------- #
# Source the distro/vendor-agnostic interactive shell setup: aliases,     #
# dircolors, git editor, etc.                                              #
. "/etc/shellrc"


# --- Prompt ------------------------------------------------------------- #
# Minimal default prompt: user@host:~/dir% (or # for root).               #
# oh-my-zsh, Starship, or the user's ~/.zshrc will override this.        #
PROMPT='%n@%m:%~%# '


# --- Pager -------------------------------------------------------------- #
# READNULLCMD is the command used when zsh reads from /dev/null (e.g.     #
# `< file`).  Fall back to /usr/bin/pager if $PAGER is unset.            #
READNULLCMD=${PAGER:-/usr/bin/pager}


# --- Key bindings ------------------------------------------------------- #
# Read terminfo entries and bind keys correctly for emacs, vi-insert, and #
# vi-command maps.  Guarded by DEBIAN_PREVENT_KEYBOARD_CHANGES so that    #
# system administrators can opt out.  The bind2maps helper is defined     #
# locally and removed immediately after use.                              #
typeset -ga debian_missing_features
if [[ -z "${DEBIAN_PREVENT_KEYBOARD_CHANGES-}" ]] && [[ "$TERM" != 'emacs' ]]; then
  typeset -A key
  key=(
    BackSpace  "${terminfo[kbs]}"
    Home       "${terminfo[khome]}"
    End        "${terminfo[kend]}"
    Insert     "${terminfo[kich1]}"
    Delete     "${terminfo[kdch1]}"
    Up         "${terminfo[kcuu1]}"
    Down       "${terminfo[kcud1]}"
    Left       "${terminfo[kcub1]}"
    Right      "${terminfo[kcuf1]}"
    PageUp     "${terminfo[kpp]}"
    PageDown   "${terminfo[knp]}"
  )

  function bind2maps () {
    local i sequence widget
    local -a maps
    while [[ "$1" != "--" ]]; do
      maps+=( "$1" )
      shift
    done
    shift
    sequence="${key[$1]}"
    widget="$2"
    [[ -z "$sequence" ]] && return 1
    for i in "${maps[@]}"; do
      bindkey -M "$i" "$sequence" "$widget"
    done
  }

  bind2maps emacs             -- BackSpace   backward-delete-char
  bind2maps       viins       -- BackSpace   vi-backward-delete-char
  bind2maps             vicmd -- BackSpace   vi-backward-char
  bind2maps emacs             -- Home        beginning-of-line
  bind2maps       viins vicmd -- Home        vi-beginning-of-line
  bind2maps emacs             -- End         end-of-line
  bind2maps       viins vicmd -- End         vi-end-of-line
  bind2maps emacs viins       -- Insert      overwrite-mode
  bind2maps             vicmd -- Insert      vi-insert
  bind2maps emacs             -- Delete      delete-char
  bind2maps       viins vicmd -- Delete      vi-delete-char
  bind2maps emacs viins vicmd -- Up          up-line-or-search
  bind2maps emacs viins vicmd -- Down        down-line-or-search
  bind2maps emacs viins vicmd -- PageUp      history-beginning-search-backward
  bind2maps emacs viins vicmd -- PageDown    history-beginning-search-forward
  bind2maps emacs             -- Left        backward-char
  bind2maps       viins vicmd -- Left        vi-backward-char
  bind2maps emacs             -- Right       forward-char
  bind2maps       viins vicmd -- Right       vi-forward-char

  # Enable application-mode (smkx) on line-init and restore normal mode
  # (rmkx) on line-finish so that terminfo sequences are sent correctly.
  if (( ${+terminfo[smkx]} )) && (( ${+terminfo[rmkx]} )); then
    function zle-line-init () {
      emulate -L zsh
      printf '%s' ${terminfo[smkx]}
    }
    function zle-line-finish () {
      emulate -L zsh
      printf '%s' ${terminfo[rmkx]}
    }
    zle -N zle-line-init
    zle -N zle-line-finish
  else
    for i in {s,r}mkx; do
      (( ${+terminfo[$i]} )) || debian_missing_features+=($i)
    done
    unset i
  fi
  unfunction bind2maps
fi


# --- Completion styles -------------------------------------------------- #
# Configure zsh's completion system via zstyle patterns before compinit   #
# is called.  oh-my-zsh will call compinit itself (see skip_global_compinit
# below), so these styles are set unconditionally here.                   #

# Extend sudo completion's command search path to include sbin directories.
zstyle ':completion:*:sudo:*' command-path \
    /usr/local/sbin \
    /usr/local/bin  \
    /usr/sbin       \
    /usr/bin        \
    /sbin           \
    /bin            \
    /usr/X11R6/bin

zstyle ':completion:*' auto-description 'specify: %d'
# Completers in order: expand globs, complete, correct typos, approximate.
zstyle ':completion:*' completer _expand _complete _correct _approximate
zstyle ':completion:*' format 'Completing %d'
zstyle ':completion:*' group-name ''
# Use LS_COLORS for completion list colouring when available.
zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' list-colors ''
zstyle ':completion:*' list-prompt %SAt %p: Hit TAB for more, or the character to insert%s
# Case-insensitive matching, then case-insensitive partial, then partial.
zstyle ':completion:*' matcher-list '' 'm:{a-z}={A-Z}' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=* l:|=*'
# Show a scrollable menu when the list is long (select=long).
zstyle ':completion:*' menu select=long
zstyle ':completion:*' select-prompt %SScrolling active: current selection at %p%s
zstyle ':completion:*' use-compctl false
zstyle ':completion:*' verbose true
# Highlight running processes in kill completion.
zstyle ':completion:*:*:kill:*:processes' list-colors '=(#b) #([0-9]#)*=0=01;31'
zstyle ':completion:*:kill:*' command 'ps -u $USER -o pid,%cpu,tty,cputime,cmd'


# --- Completion init ----------------------------------------------------- #
# We call compinit here (after all zstyles above are set) so our styles   #
# take effect before any completions are loaded.                           #
# skip_global_compinit is an oh-my-zsh variable: when oh-my-zsh.sh is    #
# sourced later it checks this flag and skips its own internal compinit   #
# call.  This ensures compinit runs exactly once — here, not inside omz. #
skip_global_compinit=1
autoload -Uz compinit
compinit


# --- run-help ----------------------------------------------------------- #
# Unalias the built-in 'run-help' alias (which points to 'man') and load  #
# the real autoloadable function that understands zsh builtins.           #
(( ${+aliases[run-help]} )) && unalias run-help
autoload -Uz run-help


# --- History ------------------------------------------------------------ #
bindkey -e                        # emacs-style line editing
HISTSIZE=10000                    # lines kept in memory
SAVEHIST=5000                     # lines written to HISTFILE
HISTFILE="$HOME/.zsh_history"
setopt histignorealldups          # remove older duplicate entries when adding
setopt sharehistory               # share history across all sessions in real time
setopt extended_history           # record timestamp and duration for each command
setopt hist_ignore_space          # commands prefixed with a space are not saved


# --- UTF-8 combining characters ---------------------------------------- #
# Allow correct display of characters composed from a base + combining    #
# codepoint (e.g. accented letters built from two Unicode code points).   #
if [[ "$(locale LC_CTYPE)" == "UTF-8" ]]; then
  setopt COMBINING_CHARS
fi


# --- Terminal program integration --------------------------------------- #
# Source a terminal-specific rc file from the same directory as this file #
# if present (e.g. installed by Terminal.app or iTerm2).  Intentionally   #
# last so it can override anything above.                                  #
# ${(%):-%x} expands to this file's path; :h strips to the directory.    #
() {
  local _zshrc_dir="${${(%):-%x}:h}"
  [ -r "${_zshrc_dir}/zshrc_$TERM_PROGRAM" ] && . "${_zshrc_dir}/zshrc_$TERM_PROGRAM"
}
