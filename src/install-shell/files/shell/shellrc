# System-wide interactive shell configuration shared across bash and zsh.
# Sourced by /etc/bash.bashrc (bash) and /etc/zsh/zshrc (zsh).

# If not running interactively, don't do anything.
case $- in
  *i*) ;;
    *) return;;
esac

# --- Environment ---
# Ensure shared env vars (PATH, XDG, umask, extend_path) are set even when this
# file is reached without a prior login shell (e.g. bash non-login interactive).
# The sentinel in shellenv makes this a no-op if already sourced.
. "/etc/shellenv"

# --- GPG TTY ---
# Tell GPG (and pinentry) which terminal to use for passphrase prompts.
# $TTY is set by the shell at startup — faster and more reliable than $(tty),
# and safe to use even during p10k instant prompt's stdin-redirect phase.
# Fix for 'gpg: signing failed: Inappropriate ioctl for device'
# - https://stackoverflow.com/questions/57591432/gpg-signing-failed-inappropriate-ioctl-for-device-on-macos-with-maven
# - https://github.com/Homebrew/homebrew-core/issues/14737#issuecomment-309848851
# - https://github.com/keybase/keybase-issues/issues/1712#issuecomment-372158682
# - https://dev.gnupg.org/T3412
# - https://github.com/romkatv/powerlevel10k?tab=readme-ov-file#how-do-i-export-gpg_tty-when-using-instant-prompt
export GPG_TTY=$TTY
# Refresh the agent's TTY reference for this terminal session.  Ensures
# pinentry appears in the current terminal even if the agent was started
# in a different one.  No-op if gpg-connect-agent is not installed.
if command -v gpg-connect-agent >/dev/null 2>&1; then
    gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1
fi

# --- Git editor ---
# When inside VS Code and no git editor is already configured, use the VS Code
# CLI as the editor for commit messages, rebases, etc.
# Detects stable vs Insiders by inspecting $VSCODE_GIT_ASKPASS_MAIN, which VS Code
# injects with the path to the running installation (case-insensitive match).
if command -v git >/dev/null 2>&1 && [ -z "$(git config --get core.editor)" ] && [ -z "${GIT_EDITOR}" ]; then
    if [ "${TERM_PROGRAM}" = "vscode" ]; then
        _vscode_path=$(printf '%s' "${VSCODE_GIT_ASKPASS_MAIN-}" | tr '[:upper:]' '[:lower:]')
        case "$_vscode_path" in
            *insiders*) export GIT_EDITOR="code-insiders --wait" ;;
            *code*)     export GIT_EDITOR="code --wait" ;;
        esac
        unset _vscode_path
    fi
fi

# --- Colors ---
# Enable LS_COLORS and colorize common commands if dircolors is available.
# Respects a per-user ~/.dircolors override if present.
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias dir='dir --color=auto'
    alias vdir='vdir --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi


# --- Aliases ---
# System-wide aliases shared across bash and zsh.
. "/etc/shellaliases"

